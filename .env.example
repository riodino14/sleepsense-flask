# ─────────────────────────────────────────────
# SleepSense API - Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke GitHub!
# ─────────────────────────────────────────────

# Gemini API Key (dapatkan dari https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Port (default 5000)
PORT=5000
